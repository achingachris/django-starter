# This is a template for the `.env` file that is used as part of local development.
# You can copy this file, rename it to `.env` and fill in the missing values,
# then delete this header.
###############################################################################

# This file should contain all the secrets required by *development* (local) application.
# This file is ignored by git by default to avoid accidentally exposing secrets in your repository.

SECRET_KEY="django-insecure-2iEsfxzHLTfdRLJ3rpxS5iaBzQYMR1dXU6ZCfNaa"

# Local development runs natively against SQLite. Leave DATABASE_URL unset to use the
# SQLite database at db.sqlite3 (configured in config/settings/base.py).
# In production, set DATABASE_URL to your Postgres instance, e.g.:
# DATABASE_URL="postgresql://postgres:postgres@db:5432/chrisdevcode"

# Redis is optional for native local development. Background tasks run eagerly
# (CELERY_TASK_ALWAYS_EAGER defaults to True in DEBUG) and the cache uses DummyCache.
# Point this at a running Redis instance if you want to exercise Celery/cache locally.
# REDIS_URL="redis://localhost:6379"

GOOGLE_ANALYTICS_ID=""

# Development server ports
DJANGO_PORT=8000
DJANGO_VITE_PORT=5173

# Docker service ports
POSTGRES_PORT=5432
REDIS_PORT=6379

# turnstile setup - add your keys here to enable turnstile
TURNSTILE_KEY=""
TURNSTILE_SECRET=""

ENABLE_DEBUG_TOOLBAR=True

# Dev superuser auto-created by `runserver` in DEBUG (defaults shown). Override if you like.
# DEV_SUPERUSER_EMAIL="admin@example.com"
# DEV_SUPERUSER_PASSWORD="admin"

EMAIL_BACKEND="django.core.mail.backends.smtp.EmailBackend"
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER="your-email@example.com"
EMAIL_HOST_PASSWORD="your-gmail-app-password-here"
DEFAULT_FROM_EMAIL="your-email@example.com"
SERVER_EMAIL="your-email@example.com"


# You can uncomment these settings to use a different email backend in config/settings/base.py.
# Depending on your selected backend, you will probably need to add additional settings / environment variables

# EMAIL_BACKEND="anymail.backends.mailgun.EmailBackend"
# MAILGUN_API_KEY="key-***"
# MAILGUN_SENDER_DOMAIN="example.com"
